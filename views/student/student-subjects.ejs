<!doctype html>
<html lang="en" class="h-full bg-gray-900">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Exam System - My Subjects</title>
  <link rel="icon" type="image/png" href="/assets/examImg.png" />
  <link href="/output.css" rel="stylesheet">
  <link href="/style.css" rel="stylesheet">

</head>

<body class="h-full text-white font-sans antialiased">

  <%- include('../components/navbar') %>
  <%- include('../components/toast') %>

  <div class="h-[3px] w-full bg-gradient-to-r from-indigo-500 via-purple-500 to-transparent"></div>

  <main class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8">

    <div class="animate-in fade-in slide-in-from-bottom-4 duration-500 mb-8 flex flex-wrap items-end justify-between gap-4 border-b border-white/10 pb-6">
      <div>
        <p class="mb-1.5 text-xs font-semibold uppercase tracking-widest text-indigo-400">
          Current Semester
        </p>
        <h1 class="font-serif text-3xl font-bold leading-tight text-white sm:text-4xl">
          My Subjects
        </h1>
        <p class="mt-2 text-sm text-gray-400">
          <%- user.first_name %> <%- user.second_name %> &nbsp;·&nbsp;
          <% if (subjects && subjects.length > 0) { %>
          <span class="text-gray-300"><%= subjects.length %> enrolled subject<%= subjects.length !== 1 ? 's' : '' %></span>
          <% } else { %>
          No subjects enrolled
          <% } %>
        </p>
      </div>

      <% if (subjects && subjects.length > 0) { %>
      <%
        const totalDone = subjects.filter(x => (x.totalExams === x.completedExams && x.totalExams > 0)).length;
      %>
      <div class="flex flex-wrap gap-3">
        <div class="min-w-[120px] rounded-xl border border-white/10 bg-white/5 p-4 text-center backdrop-blur-sm">
          <p class="text-2xl font-bold leading-none text-white"><%= subjects.length %></p>
          <p class="mt-1.5 text-[10px] font-semibold uppercase tracking-widest text-gray-400">Subjects</p>
        </div>
        <div class="min-w-[120px] rounded-xl border border-white/10 bg-white/5 p-4 text-center backdrop-blur-sm">
          <p class="text-2xl font-bold leading-none text-amber-400"><%= subjects.length - totalDone %></p>
          <p class="mt-1.5 text-[10px] font-semibold uppercase tracking-widest text-gray-400">In Progress</p>
        </div>
        <div class="min-w-[120px] rounded-xl border border-white/10 bg-white/5 p-4 text-center backdrop-blur-sm">
          <p class="text-2xl font-bold leading-none text-emerald-400"><%= totalDone %></p>
          <p class="mt-1.5 text-[10px] font-semibold uppercase tracking-widest text-gray-400">Complete</p>
        </div>
      </div>
      <% } %>
    </div>

    <% if (subjects && subjects.length > 0) { %>

    <div class="animate-in fade-in slide-in-from-bottom-4 duration-500 delay-100 mb-6 flex flex-wrap items-center justify-between gap-3">
      <div class="flex min-w-[240px] flex-1 gap-3">
        <div class="relative w-full max-w-[340px]">
          <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 105 11a6 6 0 0012 0z" />
          </svg>
          <input class="w-full rounded-lg border border-white/10 bg-gray-800/50 py-2.5 pl-10 pr-4 text-sm text-white placeholder-gray-500 outline-none transition-colors focus:border-indigo-500 focus:bg-gray-800 focus:ring-1 focus:ring-indigo-500" id="subject-search" type="text" placeholder="Search subjects…" />
        </div>
        <div class="relative">
          <select class="appearance-none w-full cursor-pointer rounded-lg border border-white/10 bg-gray-800/50 py-2.5 pl-4 pr-10 text-sm text-gray-300 outline-none transition-colors focus:border-indigo-500 focus:bg-gray-800 focus:ring-1 focus:ring-indigo-500" id="subject-filter">
            <option value="all">All Status</option>
            <option value="pending">In Progress</option>
            <option value="done">Completed</option>
          </select>

          <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-gray-400">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </div>
        </div>
      </div>

      <div class="flex items-center rounded-lg border border-white/10 bg-gray-800/50 p-1">
        <button id="btn-list" class="flex items-center rounded-md px-3 py-1.5 text-xs font-semibold bg-indigo-500 text-white transition-all" onclick="setView('list')">
          <svg class="mr-1.5 h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01" />
          </svg>
          List
        </button>
        <button id="btn-grid" class="flex items-center rounded-md px-3 py-1.5 text-xs font-semibold text-gray-400 hover:text-white transition-all" onclick="setView('grid')">
          <svg class="mr-1.5 h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <rect x="3" y="3" width="7" height="7" />
            <rect x="14" y="3" width="7" height="7" />
            <rect x="3" y="14" width="7" height="7" />
            <rect x="14" y="14" width="7" height="7" />
          </svg>
          Grid
        </button>
      </div>
    </div>

    <div id="list-view" class="animate-in fade-in slide-in-from-bottom-4 duration-500 delay-200 block">
      <div class="w-full overflow-x-auto">
        <div class="min-w-[700px]">
          <div class="grid grid-cols-[1fr_120px_100px_10px] gap-0 px-5 py-3">
            <span class="text-[11px] font-bold uppercase tracking-widest text-gray-500">Subject</span>
            <span class="text-center text-[11px] font-bold uppercase tracking-widest text-gray-500">Status</span>
            <span class="text-center text-[11px] font-bold uppercase tracking-widest text-gray-500">Progress</span>
            <span></span>
          </div>

          <div class="rounded-2xl border border-white/10 bg-white/5 overflow-hidden" id="list-rows">
            <% subjects.forEach(function(subject, i) { %>
            <%
              const pct = subject.totalExams > 0 ? Math.round((subject.completedExams / subject.totalExams) * 100) : 0;
              const circ = 2 * Math.PI * 14; 
              const offset = circ - (pct / 100) * circ;
              const in_progress = subject.totalExams == 0 || subject.completedExams < subject.totalExams;
            %>
            <a href="/subjects/<%= subject.id %>" class="subject-card group relative grid grid-cols-[1fr_120px_100px_10px] items-center gap-0 border-b border-white/10 last:border-0 px-5 py-4 transition-colors hover:bg-white/10" data-name="<%= subject.name.toLowerCase() %>" data-pending="<%= in_progress ? 'true' : 'false' %>">

              <div class="absolute bottom-0 left-0 top-0 w-1 bg-indigo-500 opacity-0 transition-opacity group-hover:opacity-100"></div>

              <div>
                <p class="text-[15px] font-semibold text-white leading-snug"><%= subject.name %></p>
              </div>

              <div class="text-center">
                <% if (subject.totalExams == 0 || subject.completedExams < subject.totalExams) { %>
                <span class="inline-flex items-center gap-1.5 rounded-full bg-amber-500/10 px-2.5 py-1 text-[11px] font-bold uppercase tracking-wider text-amber-400">
                  <span class="h-1.5 w-1.5 rounded-full bg-amber-400"></span>
                  In Progress
                </span>
                <% } else { %>
                <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-500/10 px-2.5 py-1 text-[11px] font-bold uppercase tracking-wider text-emerald-400">
                  <svg class="h-2.5 w-2.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                    <path d="M5 13l4 4L19 7" />
                  </svg>
                  Done
                </span>
                <% } %>
              </div>

              <div class="relative flex items-center justify-center">
                <svg width="70" height="70" viewBox="0 0 36 36" class="-rotate-90">
                  <circle cx="18" cy="18" r="14" fill="none" class="stroke-white/10" stroke-width="3" />
                  <circle cx="18" cy="18" r="14" fill="none" class="stroke-indigo-500 transition-all duration-700 ease-out" stroke-width="3" stroke-dasharray="<%= circ %>" stroke-dashoffset="<%= offset %>" stroke-linecap="round" />
                </svg>
                <span class="absolute font-mono text-xs font-bold text-white" style="top: 28px;"><%= pct %>%</span>
              </div>

              <div class="flex justify-center text-indigo-400 opacity-0 transition-all duration-200 -translate-x-1 group-hover:translate-x-0 group-hover:opacity-100">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </a>
            <% }); %>
          </div>
        </div>
      </div>
    </div>

    <div id="grid-view" class="animate-in fade-in slide-in-from-bottom-4 duration-500 delay-200 hidden">
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3" id="grid-cards">
        <% const borderColors = ['#6366f1','#10b981','#f59e0b','#8b5cf6','#06b6d4','#ec4899']; %>
        <% subjects.forEach(function(subject, i) { %>
        <%
          const pct2 = subject.totalExams > 0 ? Math.round((subject.completedExams / subject.totalExams) * 100) : 0;
          const bc = borderColors[i % borderColors.length];
          const in_progress = subject.totalExams == 0 || subject.completedExams < subject.totalExams;
        %>
        <a href="/subjects/<%= subject.id %>" class="subject-card group flex flex-col overflow-hidden rounded-2xl border border-white/10 bg-white/5 p-6 transition-all duration-300 hover:border-indigo-500/50 hover:bg-white/10" data-name="<%= subject.name.toLowerCase() %>" data-pending="<%= in_progress > 0 ? 'true' : 'false' %>" style="border-top: 3px solid <%= bc %>;">

          <div class="mb-3.5 flex items-start justify-between">
            <% if (subject.totalExams == 0 || subject.completedExams < subject.totalExams) { %>
            <span class="inline-flex items-center rounded-full bg-amber-500/10 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider text-amber-400"><%= subject.totalExams - subject.completedExams %> left</span>
            <% } else { %>
            <span class="inline-flex items-center rounded-full bg-emerald-500/10 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider text-emerald-400">Done</span>
            <% } %>
          </div>

          <h3 class="mb-1.5 flex-1 text-lg font-bold leading-tight text-white group-hover:text-indigo-300 transition-colors">
            <%= subject.name %>
          </h3>

          <div class="mt-auto">
            <div class="mb-1.5 flex justify-between">
              <span class="text-[11px] text-gray-400">Progress</span>
              <span class="font-mono text-[11px] font-bold text-white"><%= pct2 %>%</span>
            </div>
            <div class="h-1.5 w-full overflow-hidden rounded-full bg-white/10">
              <div class="h-full rounded-full transition-all duration-700 ease-out" style="width: <%= pct2 %>%; background-color: <%= bc %>;"></div>
            </div>
            <% if (subject.totalExams !== undefined) { %>
            <p class="mt-2 text-[11px] text-gray-500"><%= subject.completedExams %> / <%= subject.totalExams %> exams</p>
            <% } %>
          </div>
        </a>
        <% }); %>
      </div>
    </div>

    <div id="no-results" class="hidden flex-col items-center justify-center text-center py-16">
      <div class="mb-3 inline-flex h-12 w-12 items-center justify-center rounded-full bg-white/5">
        <svg class="h-6 w-6 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-4.35-4.35M17 11A6 6 0 105 11a6 6 0 0012 0z" />
        </svg>
      </div>
      <p class="text-base font-semibold text-white">No subjects found</p>
      <p class="mt-1 text-sm text-gray-400">Try a different search or filter.</p>
    </div>

    <!-- there's no subjects  -->
    <% } else { %>

    <div class="animate-in fade-in slide-in-from-bottom-4 duration-500 delay-200 flex flex-col items-center justify-center text-center py-24">
      <div class="mb-5 flex h-16 w-16 items-center justify-center rounded-2xl border border-white/10 bg-white/5">
        <svg class="h-8 w-8 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0118 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
        </svg>
      </div>
      <h2 class="font-serif text-2xl font-bold text-white mb-2">No Subjects Yet</h2>
      <p class="max-w-[300px] text-sm text-gray-400">You haven't been enrolled in any subjects. Please contact your administrator.</p>
      <a href="/student/dashboard" class="mt-6 inline-flex items-center gap-2 rounded-lg bg-indigo-500 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-indigo-400">
        ← Back to Dashboard
      </a>
    </div>

    <% } %>

  </main>

  <script src="/script.js"></script>
  <script>
    let currentView = 'list';

    function setView(v) {
      currentView = v;
      document.getElementById('list-view').style.display = v === 'list' ? 'block' : 'none';
      document.getElementById('grid-view').style.display = v === 'grid' ? 'block' : 'none';

      const btnList = document.getElementById('btn-list');
      const btnGrid = document.getElementById('btn-grid');

      const activeClasses = 'flex items-center rounded-md px-3 py-1.5 text-xs font-semibold bg-indigo-500 text-white transition-all'.split(' ');
      const inactiveClasses = 'flex items-center rounded-md px-3 py-1.5 text-xs font-semibold text-gray-400 hover:text-white transition-all'.split(' ');

      if (v === 'list') {
        btnList.className = activeClasses.join(' ');
        btnGrid.className = inactiveClasses.join(' ');
      } else {
        btnGrid.className = activeClasses.join(' ');
        btnList.className = inactiveClasses.join(' ');
      }
    }

    function filterCards() {
      const q = (document.getElementById('subject-search').value || '').toLowerCase().trim();
      const f = document.getElementById('subject-filter').value;
      const cards = document.querySelectorAll('.subject-card');
      let visible = 0;

      cards.forEach(card => {
        const name = card.dataset.name || '';
        const pending = card.dataset.pending === 'true';
        const matchQ = name.includes(q);
        const matchF = f === 'all' || (f === 'pending' && pending) || (f === 'done' && !pending);

        const show = matchQ && matchF;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      const nr = document.getElementById('no-results');
      if (nr) {
        if (visible === 0) {
          nr.classList.remove('hidden');
          nr.classList.add('flex');
        } else {
          nr.classList.add('hidden');
          nr.classList.remove('flex');
        }
      }
    }

    document.getElementById('subject-search')?.addEventListener('input', filterCards);
    document.getElementById('subject-filter')?.addEventListener('change', filterCards);
  </script>

</body>

</html>