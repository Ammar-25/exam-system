<!doctype html>
<html lang="en" class="h-full bg-gray-900">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Exam System - Exam History</title>
  <link rel="icon" type="image/png" href="/assets/examImg.png" />
  <link href="/output.css" rel="stylesheet">
  <link href="/style.css" rel="stylesheet">
</head>

<body class="h-full text-white font-sans antialiased">

  <%- include('../components/navbar') %>
  <%- include('../components/toast') %>

  <div class="h-[3px] w-full bg-gradient-to-r from-indigo-500 via-purple-500 to-transparent"></div>

  <main class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8">

    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-sm text-gray-400 mb-3">
      <a href="/student/dashboard" class="hover:text-white transition-colors">Dashboard</a>
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
      <span class="text-white">Exam History</span>
    </div>

    <!-- Header -->
    <div class="animate-in fade-in slide-in-from-bottom-4 duration-500 mb-8 flex flex-wrap items-end justify-between gap-4 border-b border-white/10 pb-6">
      <div>
        <h1 class="font-serif text-3xl font-bold leading-tight text-white sm:text-4xl">
          Exam History
        </h1>
        <p class="mt-2 text-sm text-gray-400">
          <%- user.first_name %> <%- user.second_name %> &nbsp;·&nbsp;
          <% if (exams && exams.length > 0) { %>
          <span class="text-gray-300"><%= exams.length %> exam<%= exams.length !== 1 ? 's' : '' %> taken</span>
          <% } else { %>
          No exams taken yet
          <% } %>
        </p>
      </div>

      <% if (exams && exams.length > 0) { %>
      <%
        const passed    = exams.filter(e => e.score >= e.passingScore).length;
        const failed    = exams.filter(e => e.score < e.passingScore).length;
        const avgScore  = Math.round(exams.reduce((s, e) => s + e.score, 0) / exams.length);
      %>
      <div class="flex flex-wrap gap-3">
        <div class="min-w-[120px] rounded-xl border border-white/10 bg-white/5 p-4 text-center backdrop-blur-sm">
          <p class="text-2xl font-bold leading-none text-white"><%= exams.length %></p>
          <p class="mt-1.5 text-[10px] font-semibold uppercase tracking-widest text-gray-400">Total</p>
        </div>
        <div class="min-w-[120px] rounded-xl border border-white/10 bg-white/5 p-4 text-center backdrop-blur-sm">
          <p class="text-2xl font-bold leading-none text-emerald-400"><%= passed %></p>
          <p class="mt-1.5 text-[10px] font-semibold uppercase tracking-widest text-gray-400">Passed</p>
        </div>
        <div class="min-w-[120px] rounded-xl border border-white/10 bg-white/5 p-4 text-center backdrop-blur-sm">
          <p class="text-2xl font-bold leading-none text-rose-400"><%= failed %></p>
          <p class="mt-1.5 text-[10px] font-semibold uppercase tracking-widest text-gray-400">Failed</p>
        </div>
        <div class="min-w-[120px] rounded-xl border border-white/10 bg-white/5 p-4 text-center backdrop-blur-sm">
          <p class="text-2xl font-bold leading-none text-indigo-400"><%= avgScore %>%</p>
          <p class="mt-1.5 text-[10px] font-semibold uppercase tracking-widest text-gray-400">Avg Score</p>
        </div>
      </div>
      <% } %>
    </div>

    <% if (exams && exams.length > 0) { %>

    <!-- Filters + View Toggle -->
    <div class="animate-in fade-in slide-in-from-bottom-4 duration-500 delay-100 mb-6 flex flex-wrap items-center justify-between gap-3">
      <div class="flex min-w-[240px] flex-1 gap-3 flex-wrap">

        <!-- Search -->
        <div class="relative w-full max-w-[300px]">
          <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 105 11a6 6 0 0012 0z" />
          </svg>
          <input id="exam-search" type="text" placeholder="Search exams or subjects…" class="w-full rounded-lg border border-white/10 bg-gray-800/50 py-2.5 pl-10 pr-4 text-sm text-white placeholder-gray-500 outline-none transition-colors focus:border-indigo-500 focus:bg-gray-800 focus:ring-1 focus:ring-indigo-500" />
        </div>

        <!-- Result filter -->
        <div class="relative">
          <select id="result-filter" class="appearance-none cursor-pointer rounded-lg border border-white/10 bg-gray-800/50 py-2.5 pl-4 pr-10 text-sm text-gray-300 outline-none transition-colors focus:border-indigo-500 focus:bg-gray-800 focus:ring-1 focus:ring-indigo-500">
            <option value="all">All Results</option>
            <option value="passed">Passed</option>
            <option value="failed">Failed</option>
          </select>
          <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-gray-400">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </div>
        </div>

        <!-- Subject filter -->
        <div class="relative">
          <select id="subject-filter" class="appearance-none cursor-pointer rounded-lg border border-white/10 bg-gray-800/50 py-2.5 pl-4 pr-10 text-sm text-gray-300 outline-none transition-colors focus:border-indigo-500 focus:bg-gray-800 focus:ring-1 focus:ring-indigo-500">
            <option value="all">All Subjects</option>
            <% const uniqueSubjects = [...new Set(exams.map(e => e.subjectName))]; %>
            <% uniqueSubjects.forEach(function(sub) { %>
            <option value="<%= sub.toLowerCase() %>"><%= sub %></option>
            <% }); %>
          </select>
          <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-gray-400">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </div>
        </div>
      </div>

      <!-- View Toggle -->
      <div class="flex items-center rounded-lg border border-white/10 bg-gray-800/50 p-1">
        <button id="btn-list" onclick="setView('list')" class="flex items-center rounded-md px-3 py-1.5 text-xs font-semibold bg-indigo-500 text-white transition-all">
          <svg class="mr-1.5 h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01" />
          </svg>
          List
        </button>
        <button id="btn-grid" onclick="setView('grid')" class="flex items-center rounded-md px-3 py-1.5 text-xs font-semibold text-gray-400 hover:text-white transition-all">
          <svg class="mr-1.5 h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <rect x="3" y="3" width="7" height="7" />
            <rect x="14" y="3" width="7" height="7" />
            <rect x="3" y="14" width="7" height="7" />
            <rect x="14" y="14" width="7" height="7" />
          </svg>
          Grid
        </button>
      </div>
    </div>

    <!-- ── LIST VIEW ── -->
    <div id="list-view" class="animate-in fade-in slide-in-from-bottom-4 duration-500 delay-200 block">
      <div class="w-full overflow-x-auto">
        <div class="min-w-[780px]">

          <!-- Column headers -->
          <div class="grid grid-cols-[1fr_160px_110px_130px_100px_12px] gap-0 px-5 py-3">
            <span class="text-[11px] font-bold uppercase tracking-widest text-gray-500">Exam / Subject</span>
            <span class="text-center text-[11px] font-bold uppercase tracking-widest text-gray-500">Date</span>
            <span class="text-center text-[11px] font-bold uppercase tracking-widest text-gray-500">Result</span>
            <span class="text-center text-[11px] font-bold uppercase tracking-widest text-gray-500">Score</span>
            <span class="text-center text-[11px] font-bold uppercase tracking-widest text-gray-500">Grade</span>
            <span></span>
          </div>

          <div class="rounded-2xl border border-white/10 bg-white/5 overflow-hidden" id="list-rows">
            <% exams.forEach(function(exam) { %>
            <%
              const passed      = exam.score >= exam.passingScore;
              const pct         = exam.score;
              const circ        = 2 * Math.PI * 14;
              const offset      = circ - (pct / 100) * circ;
              const scoreColor  = pct >= 85 ? '#10b981' : pct >= 60 ? '#6366f1' : '#f43f5e';
              const grade       = pct >= 90 ? 'A+' : pct >= 85 ? 'A' : pct >= 80 ? 'B+' : pct >= 75 ? 'B' : pct >= 70 ? 'C+' : pct >= 60 ? 'C' : pct >= 50 ? 'D' : 'F';
              const dateStr     = new Date(exam.takenAt).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' });
            %>
            <a href="/exams/<%= exam.id %>/result" class="exam-card group relative grid grid-cols-[1fr_160px_110px_130px_100px_12px] items-center gap-0 border-b border-white/10 last:border-0 px-5 py-4 transition-colors hover:bg-white/10" data-name="<%= exam.title.toLowerCase() %>" data-subject="<%= exam.subjectName.toLowerCase() %>" data-result="<%= passed ? 'passed' : 'failed' %>">

              <!-- Hover accent -->
              <div class="absolute bottom-0 left-0 top-0 w-1 opacity-0 transition-opacity group-hover:opacity-100" style="background-color: <%= scoreColor %>;"></div>

              <!-- Name + subject -->
              <div>
                <p class="text-[15px] font-semibold text-white leading-snug"><%= exam.title %></p>
                <p class="mt-0.5 text-xs text-gray-500"><%= exam.subjectName %></p>
              </div>

              <!-- Date -->
              <div class="text-center">
                <p class="text-sm text-gray-300"><%= dateStr %></p>
                <p class="mt-0.5 text-[11px] text-gray-500"><%= exam.duration %> min</p>
              </div>

              <!-- Result badge -->
              <div class="text-center">
                <% if (passed) { %>
                <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-500/10 px-2.5 py-1 text-[11px] font-bold uppercase tracking-wider text-emerald-400">
                  <svg class="h-2.5 w-2.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                    <path d="M5 13l4 4L19 7" />
                  </svg>
                  Passed
                </span>
                <% } else { %>
                <span class="inline-flex items-center gap-1.5 rounded-full bg-rose-500/10 px-2.5 py-1 text-[11px] font-bold uppercase tracking-wider text-rose-400">
                  <svg class="h-2.5 w-2.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                    <path d="M6 18L18 6M6 6l12 12" />
                  </svg>
                  Failed
                </span>
                <% } %>
              </div>

              <!-- Score ring -->
              <div class="relative flex items-center justify-center">
                <svg width="70" height="70" viewBox="0 0 36 36" class="-rotate-90">
                  <circle cx="18" cy="18" r="14" fill="none" class="stroke-white/10" stroke-width="3" />
                  <circle cx="18" cy="18" r="14" fill="none" stroke-width="3" stroke="<%= scoreColor %>" stroke-dasharray="<%= circ %>" stroke-dashoffset="<%= offset %>" stroke-linecap="round" class="transition-all duration-700 ease-out" />
                </svg>
                <span class="absolute font-mono text-xs font-bold text-white" style="top: 28px;"><%= pct %>%</span>
              </div>

              <!-- Grade badge -->
              <div class="text-center">
                <span class="inline-flex items-center justify-center h-8 w-8 rounded-lg text-sm font-extrabold" style="background-color: <%= scoreColor %>22; color: <%= scoreColor %>; border: 1px solid <%= scoreColor %>44;">
                  <%= grade %>
                </span>
              </div>

              <!-- Chevron -->
              <div class="flex justify-center text-indigo-400 opacity-0 transition-all duration-200 -translate-x-1 group-hover:translate-x-0 group-hover:opacity-100">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </a>
            <% }); %>
          </div>
        </div>
      </div>
    </div>

    <!-- ── GRID VIEW ── -->
    <div id="grid-view" class="animate-in fade-in slide-in-from-bottom-4 duration-500 delay-200 hidden">
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3" id="grid-cards">
        <% exams.forEach(function(exam) { %>
        <%
          const passed2     = exam.score >= exam.passingScore;
          const pct2        = exam.score;
          const scoreColor2 = pct2 >= 85 ? '#10b981' : pct2 >= 60 ? '#6366f1' : '#f43f5e';
          const grade2      = pct2 >= 90 ? 'A+' : pct2 >= 85 ? 'A' : pct2 >= 80 ? 'B+' : pct2 >= 75 ? 'B' : pct2 >= 70 ? 'C+' : pct2 >= 60 ? 'C' : pct2 >= 50 ? 'D' : 'F';
          const dateStr2    = new Date(exam.takenAt).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' });
        %>
        <a href="/exams/<%= exam.id %>/result" class="exam-card group flex flex-col overflow-hidden rounded-2xl border border-white/10 bg-white/5 p-6 transition-all duration-300 hover:border-indigo-500/50 hover:bg-white/10" data-name="<%= exam.title.toLowerCase() %>" data-subject="<%= exam.subjectName.toLowerCase() %>" data-result="<%= passed2 ? 'passed' : 'failed' %>" style="border-top: 3px solid <%= scoreColor2 %>;">

          <!-- Top row: result badge + grade -->
          <div class="mb-4 flex items-center justify-between">
            <% if (passed2) { %>
            <span class="inline-flex items-center rounded-full bg-emerald-500/10 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider text-emerald-400">Passed</span>
            <% } else { %>
            <span class="inline-flex items-center rounded-full bg-rose-500/10 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider text-rose-400">Failed</span>
            <% } %>
            <span class="inline-flex items-center justify-center h-9 w-9 rounded-lg text-base font-extrabold" style="background-color: <%= scoreColor2 %>22; color: <%= scoreColor2 %>; border: 1px solid <%= scoreColor2 %>44;">
              <%= grade2 %>
            </span>
          </div>

          <!-- Exam name -->
          <h3 class="mb-0.5 text-lg font-bold leading-tight text-white group-hover:text-indigo-300 transition-colors">
            <%= exam.title %>
          </h3>
          <p class="mb-4 text-xs text-gray-500"><%= exam.subjectName %></p>

          <!-- Score bar -->
          <div class="mt-auto">
            <div class="mb-1.5 flex justify-between">
              <span class="text-[11px] text-gray-400">Score</span>
              <span class="font-mono text-[11px] font-bold text-white"><%= pct2 %>%</span>
            </div>
            <div class="h-1.5 w-full overflow-hidden rounded-full bg-white/10">
              <div class="h-full rounded-full transition-all duration-700 ease-out" style="width: <%= pct2 %>%; background-color: <%= scoreColor2 %>;"></div>
            </div>

            <!-- Meta -->
            <div class="mt-3 flex items-center justify-between text-[11px] text-gray-500">
              <span><%= dateStr2 %></span>
              <span><%= exam.correctAnswers %> / <%= exam.totalQuestions %> correct</span>
            </div>

            <!-- Passing threshold note -->
            <div class="mt-2 flex items-center gap-1.5 text-[11px]" style="color: <%= scoreColor2 %>;">
              <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M12 2a10 10 0 110 20A10 10 0 0112 2z" />
              </svg>
              Passing: <%= exam.passingScore %>%
            </div>
          </div>
        </a>
        <% }); %>
      </div>
    </div>

    <!-- No results -->
    <div id="no-results" class="hidden flex-col items-center justify-center text-center py-16">
      <div class="mb-3 inline-flex h-12 w-12 items-center justify-center rounded-full bg-white/5">
        <svg class="h-6 w-6 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-4.35-4.35M17 11A6 6 0 105 11a6 6 0 0012 0z" />
        </svg>
      </div>
      <p class="text-base font-semibold text-white">No exams found</p>
      <p class="mt-1 text-sm text-gray-400">Try a different search or filter.</p>
    </div>

    <!-- ── EMPTY STATE ── -->
    <% } else { %>
    <div class="animate-in fade-in slide-in-from-bottom-4 duration-500 delay-200 flex flex-col items-center justify-center text-center py-24">
      <div class="mb-5 flex h-16 w-16 items-center justify-center rounded-2xl border border-white/10 bg-white/5">
        <svg class="h-8 w-8 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
        </svg>
      </div>
      <h2 class="font-serif text-2xl font-bold text-white mb-2">No Exams Taken Yet</h2>
      <p class="max-w-[300px] text-sm text-gray-400">You haven't completed any exams yet. Head to your subjects to get started.</p>
      <a href="/student/subjects" class="mt-6 inline-flex items-center gap-2 rounded-lg bg-indigo-500 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-indigo-400">
        View Subjects →
      </a>
    </div>
    <% } %>

  </main>

  <script src="/script.js"></script>
  <script>
    let currentView = 'list';

    function setView(v) {
      currentView = v;
      document.getElementById('list-view').style.display = v === 'list' ? 'block' : 'none';
      document.getElementById('grid-view').style.display = v === 'grid' ? 'block' : 'none';

      const activeClasses = 'flex items-center rounded-md px-3 py-1.5 text-xs font-semibold bg-indigo-500 text-white transition-all';
      const inactiveClasses = 'flex items-center rounded-md px-3 py-1.5 text-xs font-semibold text-gray-400 hover:text-white transition-all';

      document.getElementById('btn-list').className = v === 'list' ? activeClasses : inactiveClasses;
      document.getElementById('btn-grid').className = v === 'grid' ? activeClasses : inactiveClasses;
    }

    function filterCards() {
      const q = (document.getElementById('exam-search').value || '').toLowerCase().trim();
      const result = document.getElementById('result-filter').value;
      const subject = document.getElementById('subject-filter').value;
      const cards = document.querySelectorAll('.exam-card');
      let visible = 0;

      cards.forEach(card => {
        const name = card.dataset.name || '';
        const subj = card.dataset.subject || '';
        const res = card.dataset.result || '';

        const matchQ = name.includes(q) || subj.includes(q);
        const matchResult = result === 'all' || res === result;
        const matchSubject = subject === 'all' || subj === subject;

        const show = matchQ && matchResult && matchSubject;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      const nr = document.getElementById('no-results');
      if (nr) {
        if (visible === 0) {
          nr.classList.remove('hidden');
          nr.classList.add('flex');
        } else {
          nr.classList.add('hidden');
          nr.classList.remove('flex');
        }
      }
    }

    document.getElementById('exam-search')?.addEventListener('input', filterCards);
    document.getElementById('result-filter')?.addEventListener('change', filterCards);
    document.getElementById('subject-filter')?.addEventListener('change', filterCards);
  </script>

</body>

</html>