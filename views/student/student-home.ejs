<!doctype html>
<html lang="en" class="h-full bg-gray-900">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Exam System - Home</title>
  <link rel="icon" type="image/png" href="/assets/examImg.png" />
  <link href="/output.css" rel="stylesheet">
</head>

<body class="h-full text-white">

  <% if (typeof toast !== 'undefined' && toast) { %>
  <% const isSuccess = (type !== 'error' && type !== false); %>

  <div id="toast-message" class="fixed top-5 right-5 z-9999 flex w-full max-w-sm items-center gap-3 rounded-xl border border-gray-700 bg-gray-800 p-4 shadow-xl transition-all duration-500 transform translate-x-0 opacity-100" role="alert">

    <div class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-lg <%= isSuccess ? 'bg-green-500/20 text-green-400' : 'bg-red-500/20 text-red-400' %>">
      <% if (isSuccess) { %>
      <svg class="h-6 w-6" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 11.917 9.724 16.5 19 7.5" />
      </svg>
      <% } else { %>
      <svg class="h-6 w-6" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
      </svg>
      <% } %>
    </div>

    <div class="flex-1">
      <h3 class="text-sm font-semibold text-gray-100"><%= isSuccess ? 'Success!' : 'Error!' %></h3>
      <p class="text-sm text-gray-400"><%= typeof message !== 'undefined' ? message : (isSuccess ? 'Action completed successfully.' : 'An error occurred.') %></p>
    </div>

    <button type="button" onclick="closeToast()" class="ml-auto inline-flex h-8 w-8 items-center justify-center rounded-lg bg-gray-800 text-gray-400 transition-colors hover:bg-gray-700 hover:text-white focus:outline-none focus:ring-2 focus:ring-gray-600" aria-label="Close">
      <span class="sr-only">Close</span>
      <svg class="h-4 w-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6" />
      </svg>
    </button>
  </div>
  <% } %>

  <nav class="border-b border-white/10 bg-gray-900/50 backdrop-blur-md sticky top-0 z-50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex h-20 items-center justify-between">
        <div class="flex items-center gap-3">
          <img src="/assets/examImg.png" alt="Exam System Logo" class="h-8 w-auto" />
          <span class="text-xl font-bold tracking-tight text-white"><a href="/" class="hover:text-white transition-colors">Exam System</a></span>
        </div>

        <div class="flex items-center gap-4">
          <!-- Notification Bell with Dropdown -->
          <div class="relative" id="notif-wrapper">
            <button onclick="toggleNotif()" class="cursor-pointer relative text-gray-400 hover:text-white transition-colors focus:outline-none" id="notif-btn">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" />
              </svg>
              <!-- Red badge -->
              <% if (notifications.length > 0) { %>
              <span id="notif-badge" class="absolute -top-1 -right-1 flex h-4 w-4 items-center justify-center rounded-full bg-red-500 text-[10px] font-bold text-white"> <%- notifications.length %> </span>
              <% } %>
            </button>

            <!-- Dropdown -->
            <div id="notif-dropdown" class="hidden absolute right-0 mt-3 w-80 rounded-xl border border-white/10 bg-gray-900 shadow-xl z-50 overflow-hidden">
              <!-- Header -->
              <div class="flex items-center justify-between px-4 py-3 border-b border-white/10">
                <span class="text-sm font-semibold text-white">Notifications</span>
                <button onclick="markAllRead()" class="text-xs text-indigo-400 hover:text-indigo-300 transition-colors cursor-pointer">Mark all as read</button>
              </div>

              <!-- Notification List -->
              <ul class="divide-y divide-white/10 max-h-72 overflow-y-auto" id="notif-list">
                <% if (notifications && notifications.length > 0) { %>
                <% notifications.forEach(notification => { %>
                <li class="flex gap-3 px-4 py-3 bg-indigo-500/5 hover:bg-white/5 transition-colors notif-item unread">
                  <div class="mt-1 flex-shrink-0 h-2 w-2 rounded-full bg-indigo-400 self-start mt-2"></div>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-white"><%- notification.message %></p>
                    <p class="text-xs text-gray-400 mt-0.5 "><%- notification.title %></p>
                    <!-- <p class="text-xs text-gray-500 mt-1">2 hours ago</p> -->
                  </div>
                </li>
                <% }) %>
                <% } else { %>
                <li class="px-4 py-6 text-center text-sm text-gray-500">
                  You have no notifications.
                </li>
                <% } %>
              </ul>

              <!-- Footer -->
              <div class="px-4 py-3 border-t border-white/10 text-center">
                <a href="/notifications" class="text-xs text-indigo-400 hover:text-indigo-300 transition-colors">View all notifications</a>
              </div>
            </div>
          </div>

          <div class="relative ml-3">
            <div class="flex items-center gap-3">
              <!-- <span class="text-sm font-medium text-gray-300 hidden sm:block">Welcome, <%= typeof user !== 'undefined' ? user.first_name : 'Student' %></span>
              <button type="button" class="flex rounded-full bg-gray-800 text-sm focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-gray-800" id="user-menu-button">
                <img class="h-8 w-8 rounded-full border border-gray-600" src="https://ui-avatars.com/api/?name=Student&background=6366f1&color=fff" alt="User Avatar" />
              </button> -->
              <button onclick="logout()" class="text-sm font-semibold text-red-400 hover:text-red-300 ml-2 transition-colors bg-red-900/40 p-2 rounded-md cursor-pointer">Logout</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </nav>

  <main class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">

    <!-- <div class="mb-8">
      <h1 class="text-3xl font-bold tracking-tight text-white">Dashboard</h1>
      <p class="mt-2 text-sm text-gray-400">Overview of your academic progress and quick links.</p>
    </div> -->

    <div class="animate-in delay-1 mb-8 rounded-2xl border border-white/10 bg-gradient-to-br from-indigo-500/10 via-gray-800 to-gray-800 p-6 sm:p-8 overflow-hidden relative">
      <div class="absolute -top-10 -right-10 h-48 w-48 rounded-full bg-indigo-500/10 blur-3xl pointer-events-none"></div>
      <div class="absolute -bottom-10 -left-10 h-32 w-32 rounded-full bg-violet-500/10 blur-3xl pointer-events-none"></div>
      <div class="relative flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
          <p class="text-sm font-medium text-indigo-400 mb-1">Welcome back 👋</p>
          <h1 class="text-2xl sm:text-3xl font-bold text-white" id="welcome-name"> <%- user.first_name + " " + user.second_name%> </h1>
          <% if (examsToAttend > 1) { %>
          <p class="mt-1 text-sm text-gray-400">You have <span class="text-white font-medium"><%- examsToAttend %> not attended exams</span>. Keep it up!</p>
          <% } else if (examsToAttend === 1) { %>
          <p class="mt-1 text-sm text-gray-400">You have <span class="text-white font-medium"><%- examsToAttend %> not attended exam</span>. Keep it up!</p>
          <% } else { %>
          <p class="mt-1 text-sm text-gray-400">
            <span class="text-white font-medium">All exams completed.</span> Take a well-deserved break! 🎉
          </p>
          <% } %>
        </div>
        <a href="/exams" class="inline-flex items-center gap-2 self-start sm:self-auto rounded-lg bg-indigo-500 px-4 py-2.5 text-sm font-semibold text-white hover:bg-indigo-400 transition-colors whitespace-nowrap">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
          </svg>
          View Exams
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">

      <a href="/subjects" class="group relative flex flex-col justify-between overflow-hidden rounded-2xl bg-white/5 p-6 border border-white/10 hover:bg-white/10 hover:border-indigo-500/50 transition-all duration-300">
        <div>
          <div class="group-hover:rotate-2 inline-flex h-12 w-12 items-center justify-center rounded-lg bg-indigo-500/20 text-indigo-400 mb-4 group-hover:scale-110 transition-transform">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white">My Subjects</h3>
          <p class="mt-2 text-sm text-gray-400">Browse your enrolled subjects, study materials, and take pending exams.</p>
        </div>
        <div class="mt-6 flex items-center text-sm font-medium text-indigo-400 group-hover:text-indigo-300">
          View Subjects <span aria-hidden="true" class="ml-1">&rarr;</span>
        </div>
      </a>

      <a href="/results" class="group relative flex flex-col justify-between overflow-hidden rounded-2xl bg-white/5 p-6 border border-white/10 hover:bg-white/10 hover:border-indigo-500/50 transition-all duration-300">
        <div>
          <div class="group-hover:rotate-2 inline-flex h-12 w-12 items-center justify-center rounded-lg bg-emerald-500/20 text-emerald-400 mb-4 group-hover:scale-110 transition-transform">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white">Results & History</h3>
          <p class="mt-2 text-sm text-gray-400">Check your grades, view past exam submissions, and track your performance.</p>
        </div>
        <div class="mt-6 flex items-center text-sm font-medium text-emerald-400 group-hover:text-emerald-300">
          View Results <span aria-hidden="true" class="ml-1">&rarr;</span>
        </div>
      </a>

      <a href="/student/profile" class="group relative flex flex-col justify-between overflow-hidden rounded-2xl bg-white/5 p-6 border border-white/10 hover:bg-white/10 hover:border-indigo-500/50 transition-all duration-300">
        <div>
          <div class="group-hover:rotate-2 inline-flex h-12 w-12 items-center justify-center rounded-lg bg-amber-500/20 text-amber-400 mb-4 group-hover:scale-110 transition-transform">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white">My Profile</h3>
          <p class="mt-2 text-sm text-gray-400">Manage your personal information, update your password, and view account details.</p>
        </div>
        <div class="mt-6 flex items-center text-sm font-medium text-amber-400 group-hover:text-amber-300">
          Edit Profile <span aria-hidden="true" class="ml-1">&rarr;</span>
        </div>
      </a>

    </div>

  </main>

  <script src="/script.js"></script>

</body>

</html>