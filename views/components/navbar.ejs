  <nav class="border-b border-white/10 bg-gray-900/50 backdrop-blur-md sticky top-0 z-50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex h-20 items-center justify-between">
        <div class="flex items-center gap-3">
          <img src="/assets/examImg.png" alt="Exam System Logo" class="h-8 w-auto" />
          <span class="text-xl font-bold tracking-tight text-white"><a href="/student/dashboard" class="hover:text-white transition-colors">Exam System</a></span>
        </div>

        <div class="flex items-center gap-4">
          <!-- Notification Bell with Dropdown -->
          <div class="relative" id="notif-wrapper">
            <button onclick="toggleNotif()" class="flex items-center justify-center cursor-pointer relative text-gray-400 hover:text-white transition-colors focus:outline-none" id="notif-btn">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" />
              </svg>
              <!-- Red badge -->
              <% if (notifications.length > 0) { %>
              <span id="notif-badge" class="absolute -top-1 -right-1 flex h-4 w-4 items-center justify-center rounded-full bg-red-500 text-[10px] font-bold text-white"> <%- notifications.length %> </span>
              <% } %>
            </button>

            <!-- Dropdown -->
            <div id="notif-dropdown" class="hidden absolute right-0 mt-3 w-80 rounded-xl border border-white/10 bg-gray-900 shadow-xl z-50 overflow-hidden">
              <!-- Header -->
              <div class="flex items-center justify-between px-4 py-3 border-b border-white/10">
                <span class="text-sm font-semibold text-white">Notifications</span>
                <button onclick="markAllRead()" id="mark-all-read" class="text-xs text-indigo-400 hover:text-indigo-300 transition-colors cursor-pointer">Mark all as read</button>
              </div>

              <!-- Notification List -->
              <ul class="divide-y divide-white/10 max-h-72 overflow-y-auto" id="notif-list">
                <% if (notifications && notifications.length > 0) { %>
                <% notifications.forEach((notification) => { %>
                <li class="flex gap-3 px-4 py-3 bg-indigo-500/5 hover:bg-white/5 transition-colors notif-item unread" id="notif-item-<%- notification.id %>">
                  <div class="mt-2 flex-shrink-0 h-2 w-2 rounded-full bg-indigo-400 self-start notif-dot"></div>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-white"><%- notification.message %></p>
                    <p class="text-xs text-gray-400 mt-0.5"><%- notification.title %></p>
                  </div>
                  <button onclick="markOneRead('<%- notification.id %>')" class="flex-shrink-0 self-start mt-1 text-xs text-indigo-400 hover:text-indigo-200 hover:bg-indigo-500/20 transition-colors px-2 py-0.5 rounded-full border border-indigo-500/30 cursor-pointer whitespace-nowrap">
                    Mark read
                  </button>
                </li>
                <% }) %>
                <% } else { %>
                <li class="px-4 py-6 text-center text-sm text-gray-500">
                  You have no unread notifications.
                </li>
                <% } %>
              </ul>
              <!-- Footer -->
              <div class="px-4 py-3 border-t border-white/10 text-center">
                <a href="/notifications" class="text-xs text-indigo-400 hover:text-indigo-300 transition-colors">View all notifications</a>
              </div>
              <div id="notif-loading-overlay" class="absolute inset-0 z-10 flex items-center justify-center rounded-xl bg-gray-900/55 opacity-0 pointer-events-none transition-opacity duration-150 ease-in-out">
                <div class="h-[22px] w-[22px] animate-spin rounded-full border-[2.5px] border-indigo-400/25 border-t-indigo-400"></div>
              </div>
            </div>
          </div>

          <div class="relative ml-3">
            <div class="flex items-center gap-3">

              <div class="relative flex justify-center"> <a href="/student/profile" class="group flex items-center">
                  <div class="h-10 w-10 rounded-full bg-indigo-500 flex items-center justify-center text-[12px] font-bold text-white ring-4 ring-indigo-500/30 select-none">
                    <%- user.first_name[0] + user.second_name[0]%>
                  </div>

                  <div class="absolute top-full left-1/2 -translate-x-1/2 mt-3 flex flex-col items-center pointer-events-none opacity-0 translate-y-[-10px] transition-all duration-300 ease-out group-hover:opacity-100 group-hover:translate-y-0">
                    <div class="w-2 h-2 bg-gray-800 rotate-45 -mb-1"></div>
                    <span class="rounded bg-gray-800 p-2 text-xs text-white shadow-xl whitespace-nowrap">
                      My Profile
                    </span>
                  </div>
                </a>

              </div>

              <button onclick="logout()" class="text-sm font-semibold text-red-400 hover:text-red-300 transition-colors bg-red-900/40 p-2 ml-3 rounded-md cursor-pointer">
                Logout
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </nav>