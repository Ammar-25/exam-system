<div id="toast" class="fixed top-6 right-6 z-[100] hidden">
  <div class="flex items-center gap-3 rounded-xl border border-white/10 bg-gray-800 px-4 py-3 shadow-xl">
    <div id="toast-icon" class="flex h-6 w-6 items-center justify-center rounded-full bg-emerald-500/20 text-emerald-400 flex-shrink-0">
      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
      </svg>
    </div>
    <p id="toast-msg" class="text-sm font-medium text-white"></p>
  </div>
</div>

<script src="/script.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    <% if (typeof toast !== 'undefined' && toast) { %>
    const serverMessage = <%- JSON.stringify(message) %>;
    const isError = "<%= type %>" === "error";
    showToast(serverMessage, isError);
    <% } %>
  });
</script>