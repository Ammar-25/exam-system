<!doctype html>
<html lang="en" class="h-full bg-gray-900">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Exam System - Profile</title>
  <link rel="icon" type="image/png" href="/assets/examImg.png" />
  <link href="/output.css" rel="stylesheet">

  <style>
    * {
      font-family: 'Inter', sans-serif;
    }

    .animate-in {
      animation: fadeSlideIn 0.5s ease forwards;
      opacity: 0;
    }

    .delay-1 {
      animation-delay: 0.05s;
    }

    .delay-2 {
      animation-delay: 0.1s;
    }

    .delay-3 {
      animation-delay: 0.15s;
    }

    .delay-4 {
      animation-delay: 0.2s;
    }

    @keyframes fadeSlideIn {
      from {
        opacity: 0;
        transform: translateY(12px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    input:focus,
    select:focus,
    textarea:focus {
      outline: none;
    }

    /* Custom scrollbar */
    ::-webkit-scrollbar {
      width: 6px;
    }

    ::-webkit-scrollbar-track {
      background: transparent;
    }

    ::-webkit-scrollbar-thumb {
      background: #374151;
      border-radius: 3px;
    }
  </style>
</head>

<body class="h-full text-white bg-gray-900">

  <!-- NAV (identical to home) -->
  <nav class="border-b border-white/10 bg-gray-900/50 backdrop-blur-md sticky top-0 z-50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex h-20 items-center justify-between">
        <div class="flex items-center gap-3">
          <img src="/assets/examImg.png" alt="Exam System Logo" class="h-8 w-auto" onerror="this.style.display='none'" />
          <span class="text-xl font-bold tracking-tight text-white"><a href="/" class="hover:text-white transition-colors">Exam System</a></span>
        </div>

        <div class="flex items-center gap-4">
          <!-- Notification Bell -->
          <div class="relative" id="notif-wrapper">
            <button onclick="toggleNotif()" class="cursor-pointer relative text-gray-400 hover:text-white transition-colors focus:outline-none" id="notif-btn">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" />
              </svg>
              <!-- Red badge -->
              <% if (notifications.length > 0) { %>
              <span id="notif-badge" class="absolute -top-1 -right-1 flex h-4 w-4 items-center justify-center rounded-full bg-red-500 text-[10px] font-bold text-white"> <%- notifications.length %> </span>
              <% } %>
            </button>

            <!-- Dropdown -->
            <div id="notif-dropdown" class="hidden absolute right-0 mt-3 w-80 rounded-xl border border-white/10 bg-gray-900 shadow-xl z-50 overflow-hidden">
              <!-- Header -->
              <div class="flex items-center justify-between px-4 py-3 border-b border-white/10">
                <span class="text-sm font-semibold text-white">Notifications</span>
                <button onclick="markAllRead()" class="text-xs text-indigo-400 hover:text-indigo-300 transition-colors cursor-pointer">Mark all as read</button>
              </div>

              <!-- Notification List -->
              <ul class="divide-y divide-white/10 max-h-72 overflow-y-auto" id="notif-list">
                <% if (notifications && notifications.length > 0) { %>
                <% notifications.forEach(notification => { %>
                <li class="flex gap-3 px-4 py-3 bg-indigo-500/5 hover:bg-white/5 transition-colors notif-item unread">
                  <div class="mt-1 flex-shrink-0 h-2 w-2 rounded-full bg-indigo-400 self-start mt-2"></div>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-white"><%- notification.message %></p>
                    <p class="text-xs text-gray-400 mt-0.5 "><%- notification.title %></p>
                    <!-- <p class="text-xs text-gray-500 mt-1">2 hours ago</p> -->
                  </div>
                </li>
                <% }) %>
                <% } else { %>
                <li class="px-4 py-6 text-center text-sm text-gray-500">
                  You have no notifications.
                </li>
                <% } %>
              </ul>

              <!-- Footer -->
              <div class="px-4 py-3 border-t border-white/10 text-center">
                <a href="/notifications" class="text-xs text-indigo-400 hover:text-indigo-300 transition-colors">View all notifications</a>
              </div>
            </div>
          </div>

          <div class="relative ml-3">
            <button onclick="logout()" class="text-sm font-semibold text-red-400 hover:text-red-300 ml-2 transition-colors bg-red-900/40 p-2 rounded-md cursor-pointer">Logout</button>
          </div>
        </div>
      </div>
    </div>
  </nav>

  <main class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">

    <!-- Page Header -->
    <div class="animate-in delay-1 mb-8">
      <div class="flex items-center gap-2 text-sm text-gray-400 mb-3">
        <a href="/" class="hover:text-white transition-colors">Dashboard</a>
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        <span class="text-white">My Profile</span>
      </div>
      <h1 class="text-2xl sm:text-3xl font-bold text-white tracking-tight">My Profile</h1>
      <p class="mt-1 text-sm text-gray-400">Manage your personal information and account settings.</p>
    </div>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">

      <!-- LEFT COLUMN: Avatar & summary card -->
      <div class="lg:col-span-1 flex flex-col gap-6">

        <!-- Profile Card -->
        <div class="animate-in delay-1 relative overflow-hidden rounded-2xl border border-white/10 bg-gradient-to-br from-indigo-500/10 via-gray-800 to-gray-800 p-6">
          <div class="absolute -top-10 -right-10 h-40 w-40 rounded-full bg-indigo-500/10 blur-3xl pointer-events-none"></div>
          <div class="absolute -bottom-10 -left-10 h-32 w-32 rounded-full bg-violet-500/10 blur-3xl pointer-events-none"></div>

          <div class="relative flex flex-col items-center text-center gap-4">
            <!-- Avatar -->
            <div class="relative group">
              <div class="h-24 w-24 rounded-full bg-indigo-500 flex items-center justify-center text-3xl font-bold text-white ring-4 ring-indigo-500/30 select-none">
                <%- user.first_name[0] + user.second_name[0]%>
              </div>
              <!-- <button onclick="document.getElementById('avatar-input').click()" class="absolute inset-0 rounded-full bg-black/50 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity cursor-pointer">
                <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </button> -->
              <!-- <input type="file" id="avatar-input" accept="image/*" class="hidden" /> -->
            </div>

            <div>
              <h2 class="text-xl font-bold text-white"> <%- user.first_name + " " + user.second_name %> </h2>
              <p class="text-sm text-indigo-400 font-medium mt-0.5"> <%- grade.grade %> </p>
              <p class="text-xs text-gray-500 mt-1">ID: <%- user.id %></p>
            </div>

            <!-- Status badge -->
            <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-500/15 px-3 py-1 text-xs font-semibold text-emerald-400 ring-1 ring-emerald-500/30">
              <span class="h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
              Active Student
            </span>
          </div>

          <!-- Quick stats -->
          <div class="relative mt-6 grid grid-cols-3 divide-x divide-white/10 rounded-xl bg-white/5 overflow-hidden">
            <div class="flex flex-col items-center py-3 px-2">
              <span class="text-lg font-bold text-white"><%- subjects_count %></span>
              <span class="text-[10px] text-gray-400 mt-0.5 text-center leading-tight">Subjects</span>
            </div>
            <div class="flex flex-col items-center py-3 px-2">
              <span class="text-lg font-bold text-white"><%- exams %></span>
              <span class="text-[10px] text-gray-400 mt-0.5 text-center leading-tight">Exams</span>
            </div>
            <div class="flex flex-col items-center py-3 px-2">
              <% if (typeof averagePercentage === 'number' && !isNaN(averagePercentage >= 50)) { %>
              <span class="text-lg font-bold text-emerald-400"><%- (typeof averagePercentage === 'number' ? averagePercentage.toFixed(2) : 0)%> %</span>
              <% } else { %>
              <span class="text-lg font-bold text-red-400"><%- (typeof averagePercentage === 'number' ? averagePercentage.toFixed(2) : 0) %> %</span>
              <% } %>
              <span class=" text-[10px] text-gray-400 mt-0.5 text-center leading-tight">Avg Score</span>
            </div>
          </div>
        </div>

        <!-- Account Info Card -->
        <div class="animate-in delay-2 rounded-2xl border border-white/10 bg-white/5 p-5">
          <h3 class="text-sm font-semibold text-white mb-4 flex items-center gap-2">
            <svg class="h-4 w-4 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Account Info
          </h3>
          <div class="space-y-3">
            <div class="flex items-center justify-between">
              <span class="text-xs text-gray-400">Role</span>
              <span class="text-xs font-medium text-white bg-white/10 px-2 py-0.5 rounded-md">Student</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-xs text-gray-400">Level</span>
              <span class="text-xs font-medium text-white"><%- grade.grade %></span>
            </div>
          </div>
        </div>

      </div>

      <!-- RIGHT COLUMN: Edit forms -->
      <div class="lg:col-span-2 flex flex-col gap-6">

        <!-- Personal Information -->
        <div class="animate-in delay-2 rounded-2xl border border-white/10 bg-white/5 p-6">
          <div class="flex items-center justify-between mb-6">
            <div class="flex items-center gap-2">
              <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-indigo-500/20 text-indigo-400">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
              </div>
              <h3 class="text-base font-semibold text-white">Personal Information</h3>
            </div>
          </div>

          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-medium text-gray-400 uppercase tracking-wide">First Name</label>
              <input id="first-name" ype="text" value="<%- user.first_name %>" class="rounded-lg border border-white/10 bg-gray-900/60 px-4 py-2.5 text-sm text-white placeholder-gray-500 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-colors" />
            </div>

            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-medium text-gray-400 uppercase tracking-wide">Last Name</label>
              <input id="last-name" ype="text" value="Mohamed" class="rounded-lg border border-white/10 bg-gray-900/60 px-4 py-2.5 text-sm text-white placeholder-gray-500 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-colors" />
            </div>

            <div class="flex flex-col gap-1.5 sm:col-span-2">
              <label class="text-xs font-medium text-gray-400 uppercase tracking-wide">Email Address</label>
              <div class="relative">
                <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5">
                  <svg class="h-4 w-4 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <input type="email" disabled value=<%- user.email %> class="w-full rounded-lg border border-white/10 bg-gray-900/60 pl-10 pr-4 py-2.5 text-sm text-gray-400 opacity-50 cursor-not-allowed placeholder-gray-500 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-colors" />
              </div>
            </div>

            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-medium text-gray-400 uppercase tracking-wide">Phone Number</label>
              <div class="relative">
                <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5">
                  <svg class="h-4 w-4 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <input type="tel" disabled value=<%- user.phone_number%> class="w-full rounded-lg border border-white/10 bg-gray-900/60 pl-10 pr-4 py-2.5 text-sm text-gray-400 opacity-50 cursor-not-allowed placeholder-gray-500 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-colors" />
              </div>
            </div>

            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-medium text-gray-400 uppercase tracking-wide">Date of Birth</label>
              <input type="date" disabled value=<%- user.date_of_birth %> class="rounded-lg border border-white/10 bg-gray-900/60 px-4 py-2.5 text-sm text-gray-400 opacity-50 cursor-not-allowed placeholder-gray-500 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-colors [color-scheme:dark]" />
            </div>

            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-medium text-gray-400 uppercase tracking-wide">Gender</label>
              <select id="gender" class="rounded-lg border border-white/10 bg-gray-900/60 px-4 py-2.5 text-sm text-white focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-colors appearance-none cursor-pointer">
                <option value="male" ( <%- user.gender == 'male' ? 'selected' : ''%> )>Male</option>
                <option value="female" ( <%- user.gender == 'female' ? 'selected' : ''%> )>Female</option>
              </select>
            </div>

            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-medium text-gray-400 uppercase tracking-wide">National ID</label>
              <input type="text" disabled value=<%- user.national_id %> class="rounded-lg border border-white/10 bg-gray-900/60 px-4 py-2.5 text-sm text-gray-400 opacity-50 cursor-not-allowed placeholder-gray-500 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-colors" />
            </div>
          </div>

          <div class="mt-6 flex items-center justify-end gap-3">
            <button onclick="showToast('No changes to discard.')" class="rounded-lg px-4 py-2 text-sm font-medium text-gray-400 hover:text-white transition-colors">
              Cancel
            </button>
            <button onclick="updateInfo()" id="update-btn" class="inline-flex items-center gap-2 rounded-lg bg-indigo-500 px-5 py-2 text-sm font-semibold text-white hover:bg-indigo-400 active:scale-95 transition-all">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Save Changes
            </button>
          </div>
        </div>

        <!-- Change Password -->
        <div class="animate-in delay-3 rounded-2xl border border-white/10 bg-white/5 p-6">
          <div class="flex items-center gap-2 mb-6">
            <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-amber-500/20 text-amber-400">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
            </div>
            <h3 class="text-base font-semibold text-white">Change Password</h3>
          </div>

          <div class="grid grid-cols-1 gap-5">
            <!-- Current Password -->
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-medium text-gray-400 uppercase tracking-wide">Current Password</label>
              <div class="relative">
                <input type="password" id="current-pw" placeholder="Enter current password" class="w-full rounded-lg border border-white/10 bg-gray-900/60 px-4 py-2.5 pr-10 text-sm text-white placeholder-gray-500 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-colors" />
                <button onclick="togglePw('current-pw', this)" class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-500 hover:text-gray-300 transition-colors cursor-pointer">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                  </svg>
                </button>
              </div>
            </div>

            <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
              <!-- New Password -->
              <div class="flex flex-col gap-1.5">
                <label class="text-xs font-medium text-gray-400 uppercase tracking-wide">New Password</label>
                <div class="relative">
                  <input type="password" id="new-pw" placeholder="Min. 8 characters" oninput="checkStrength(this.value)" class="w-full rounded-lg border border-white/10 bg-gray-900/60 px-4 py-2.5 pr-10 text-sm text-white placeholder-gray-500 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-colors" />
                  <button onclick="togglePw('new-pw', this)" class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-500 hover:text-gray-300 transition-colors cursor-pointer">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                    </svg>
                  </button>
                </div>
                <!-- Password strength -->
                <div id="strength-bar" class="h-1 rounded-full bg-white/10 overflow-hidden mt-1">
                  <div id="strength-fill" class="h-full rounded-full transition-all duration-300 w-0 bg-red-500"></div>
                </div>
                <p id="strength-label" class="text-[11px] text-gray-500"></p>
              </div>

              <!-- Confirm Password -->
              <div class="flex flex-col gap-1.5">
                <label class="text-xs font-medium text-gray-400 uppercase tracking-wide">Confirm New Password</label>
                <div class="relative">
                  <input type="password" id="confirm-pw" placeholder="Repeat new password" class="w-full rounded-lg border border-white/10 bg-gray-900/60 px-4 py-2.5 pr-10 text-sm text-white placeholder-gray-500 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition-colors" />
                  <button onclick="togglePw('confirm-pw', this)" class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-500 hover:text-gray-300 transition-colors cursor-pointer">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                    </svg>
                  </button>
                </div>
              </div>
            </div>
          </div>

          <!-- Password requirements -->
          <ul class="mt-4 space-y-1.5">
            <li class="flex items-center gap-2 text-xs text-gray-400" id="req-length">
              <svg class="h-3.5 w-3.5 text-gray-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
              At least 8 characters
            </li>
            <li class="flex items-center gap-2 text-xs text-gray-400" id="req-upper">
              <svg class="h-3.5 w-3.5 text-gray-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
              One uppercase letter
            </li>
            <li class="flex items-center gap-2 text-xs text-gray-400" id="req-number">
              <svg class="h-3.5 w-3.5 text-gray-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
              One number
            </li>
          </ul>

          <div class="mt-6 flex items-center justify-end gap-3">
            <button onclick="showToast('No changes to discard.')" class="rounded-lg px-4 py-2 text-sm font-medium text-gray-400 hover:text-white transition-colors">
              Cancel
            </button>
            <button onclick="handlePasswordChange()" class="inline-flex items-center gap-2 rounded-lg bg-amber-500 px-5 py-2 text-sm font-semibold text-white hover:bg-amber-400 active:scale-95 transition-all">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
              Update Password
            </button>
          </div>
        </div>

        <!-- Danger Zone -->
        <div class="animate-in delay-4 rounded-2xl border border-red-500/20 bg-red-500/5 p-6">
          <div class="flex items-center gap-2 mb-4">
            <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-red-500/20 text-red-400">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
              </svg>
            </div>
            <h3 class="text-base font-semibold text-red-400">Danger Zone</h3>
          </div>
          <p class="text-sm text-gray-400 mb-4">Once you delete your account, there is no going back. All your exam history, results, and personal data will be permanently removed.</p>
          <button onclick="showDeleteConfirm()" class="inline-flex items-center gap-2 rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-2 text-sm font-semibold text-red-400 hover:bg-red-500/20 hover:text-red-300 active:scale-95 transition-all cursor-pointer">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
            </svg>
            Delete Account
          </button>
        </div>

      </div>
    </div>
  </main>

  <!-- Toast notification -->
  <div id="toast" class="fixed bottom-6 right-6 z-[100] hidden">
    <div class="flex items-center gap-3 rounded-xl border border-white/10 bg-gray-800 px-4 py-3 shadow-xl">
      <div id="toast-icon" class="flex h-6 w-6 items-center justify-center rounded-full bg-emerald-500/20 text-emerald-400 flex-shrink-0">
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <p id="toast-msg" class="text-sm font-medium text-white"></p>
    </div>
  </div>

  <!-- Delete Confirm Modal -->
  <div id="delete-modal" class="fixed inset-0 z-[200] hidden flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="closeDeleteConfirm()"></div>
    <div class="relative w-full max-w-md rounded-2xl border border-white/10 bg-gray-900 p-6 shadow-2xl">
      <div class="flex items-center gap-3 mb-4">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-red-500/20 text-red-400">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-white">Delete Account</h3>
      </div>
      <p class="text-sm text-gray-400 mb-6">This action is <span class="text-white font-semibold">permanent and irreversible</span>. All your data will be deleted immediately. Are you absolutely sure?</p>
      <div class="flex gap-3">
        <button onclick="closeDeleteConfirm()" class="flex-1 rounded-lg border border-white/10 bg-white/5 py-2.5 text-sm font-semibold text-white hover:bg-white/10 transition-colors cursor-pointer">
          Cancel
        </button>
        <button onclick="closeDeleteConfirm(); showToast('Account deletion requested.', true)" class="flex-1 rounded-lg bg-red-600 py-2.5 text-sm font-semibold text-white hover:bg-red-500 transition-colors cursor-pointer">
          Yes, Delete
        </button>
      </div>
    </div>
  </div>
  <script src="/script.js"></script>
  <script>
    const first_name = document.getElementById('first-name');
    const last_name = document.getElementById('last-name');
    const gender = document.getElementById('gender');
    const button = document.getElementById('update-btn');


    async function updateInfo() {
      let data = {
        first_name: first_name.value,
        last_name: last_name.value,
        gender: gender.value
      };

      button.disabled = true;
      button.innerHTML = `
              <svg class="h-4 w-4 animate-spin" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2a8 8 0 00-15.94-2M4 9h4m12 11v-5h-.581m0 0a8 8 0 01-15.357-2m15.357 2H20" />
              </svg>
              Saving...
              `;
      button.classList.add('opacity-70', 'cursor-not-allowed');


      try {

        const res = await apiFetch("/student/updateInfo", {
          method: 'POST',
          body: JSON.stringify(data),
          headers: {
            'Content-Type': 'application/json'
          }
        });
        if (res.ok) {
          showToast('Personal information updated successfully!');
        } else {
          showToast('Something went wrong.', true);
        }
      } catch (error) {
        showToast(error.message, true);
      } finally {
        // Re-enable button regardless of success or failure
        button.disabled = false;
        button.innerHTML = `
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
      </svg>
      Save Changes
      `;
        button.classList.remove('opacity-70', 'cursor-not-allowed');
      }
    }
  </script>


  <script>
    function togglePw(id, btn) {
      const input = document.getElementById(id);
      const isText = input.type === 'text';
      input.type = isText ? 'password' : 'text';
      btn.querySelector('svg').style.opacity = isText ? '1' : '0.5';
    }

    function checkStrength(val) {
      const fill = document.getElementById('strength-fill');
      const label = document.getElementById('strength-label');

      const checks = {
        length: val.length >= 8,
        upper: /[A-Z]/.test(val),
        number: /[0-9]/.test(val),
        special: /[^A-Za-z0-9]/.test(val),
      };

      // Update requirement icons
      updateReq('req-length', checks.length);
      updateReq('req-upper', checks.upper);
      updateReq('req-number', checks.number);

      const score = Object.values(checks).filter(Boolean).length;

      const states = [{
          w: '0%',
          color: 'bg-red-500',
          text: ''
        },
        {
          w: '25%',
          color: 'bg-red-500',
          text: 'Weak'
        },
        {
          w: '50%',
          color: 'bg-amber-500',
          text: 'Fair'
        },
        {
          w: '75%',
          color: 'bg-yellow-400',
          text: 'Good'
        },
        {
          w: '100%',
          color: 'bg-emerald-500',
          text: 'Strong'
        },
      ];

      const s = val.length === 0 ? states[0] : states[score];
      fill.style.width = s.w;
      fill.className = `h-full rounded-full transition-all duration-300 ${s.color}`;
      label.textContent = s.text;
      label.className = `text-[11px] mt-0.5 ${score >= 3 ? 'text-emerald-400' : score >= 2 ? 'text-amber-400' : 'text-red-400'}`;
    }

    function updateReq(id, passing) {
      const el = document.getElementById(id);
      const svg = el.querySelector('svg');
      if (passing) {
        svg.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>';
        svg.className = 'h-3.5 w-3.5 text-emerald-400 flex-shrink-0';
        el.className = 'flex items-center gap-2 text-xs text-emerald-400';
      } else {
        svg.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>';
        svg.className = 'h-3.5 w-3.5 text-gray-600 flex-shrink-0';
        el.className = 'flex items-center gap-2 text-xs text-gray-400';
      }
    }

    let toastTimer;

    function showToast(msg, isError = false) {
      console.log("hello World!");
      const toast = document.getElementById('toast');
      const toastMsg = document.getElementById('toast-msg');
      const toastIcon = document.getElementById('toast-icon');
      toastMsg.textContent = msg;

      if (isError) {
        toastIcon.className = 'flex h-6 w-6 items-center justify-center rounded-full bg-red-500/20 text-red-400 flex-shrink-0';
        toastIcon.innerHTML = '<svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>';
      } else {
        toastIcon.className = 'flex h-6 w-6 items-center justify-center rounded-full bg-emerald-500/20 text-emerald-400 flex-shrink-0';
        toastIcon.innerHTML = '<svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>';
      }

      toast.classList.remove('hidden');
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => toast.classList.add('hidden'), 3000);
    }

    function handlePasswordChange() {
      const cur = document.getElementById('current-pw').value;
      const newP = document.getElementById('new-pw').value;
      const conf = document.getElementById('confirm-pw').value;
      if (!cur || !newP || !conf) return showToast('Please fill in all password fields.', true);
      if (newP !== conf) return showToast('New passwords do not match.', true);
      if (newP.length < 8) return showToast('Password must be at least 8 characters.', true);
      showToast('Password updated successfully!');
    }

    function showDeleteConfirm() {
      document.getElementById('delete-modal').classList.remove('hidden');
      document.getElementById('delete-modal').classList.add('flex');
    }

    function closeDeleteConfirm() {
      document.getElementById('delete-modal').classList.add('hidden');
      document.getElementById('delete-modal').classList.remove('flex');
    }
  </script>

</body>

</html>